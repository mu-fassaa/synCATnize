[sub_resource type="Shader" id="1"]
code = "shader_type canvas_item;
uniform float speed = 5.0;
uniform float bounce_height = 8.0;
uniform float frequency = 0.03;

void vertex() {
	// Oscillating wave vertex displacement to simulate dynamic letter bounce
	float wave = sin(TIME * speed + VERTEX.x * frequency) * bounce_height;
	VERTEX.y += wave;
}"

